{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 5173
    },
    {
      "name": "frontend-remote",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev:remote"],
      "cwd": "frontend",
      "port": 5173
    },
    {
      "name": "analytics-api",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["src/server.mjs"],
      "cwd": "services/analytics-api",
      "port": 8080
    },
    {
      "name": "cloudflare-pages",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "preview:cloudflare-pages"],
      "cwd": "frontend",
      "port": 8788
    },
    {
      "name": "design-mockup",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "4321", "design"],
      "port": 4321
    }
  ]
}
