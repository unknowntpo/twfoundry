{
  "name": "twfoundry-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:rolling": "VITE_TWFOUNDRY_ANALYTICS_BASE=/data/analytics-rolling/bus vite --host 0.0.0.0",
    "dev:remote": "VITE_TWFOUNDRY_LIVE_SIGNALS=remote VITE_API_TARGET=https://twfoundry-poc.pages.dev vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "fetch:tdx-bus": "bun scripts/fetch-tdx-taipei-bus-snapshot.mjs --limit 1200 --interval-minutes 5",
    "check:tdx-token": "bun scripts/check-tdx-token.mjs",
    "fetch:tdx-bus-history": "bun scripts/fetch-tdx-taipei-bus-history.mjs --top 500000 --interval-minutes 5 --per-slot-limit 1200 --replace-manifest --force",
    "backfill:tdx-bus-projections": "bun scripts/backfill-tdx-bus-projections.mjs",
    "fetch:tdx-bus-route-context": "bun scripts/fetch-tdx-taipei-bus-route-context.mjs --from-route-list",
    "fetch:tdx-bus-route-context:archive-sample": "bun scripts/fetch-tdx-taipei-bus-route-context.mjs --from-archive --limit-routes 40",
    "audit:tdx-bus-route-quality": "bun scripts/audit-tdx-bus-route-quality.mjs",
    "sample:tdx-bus-delay-apis": "bun scripts/sample-tdx-bus-delay-apis.mjs",
    "build:tdx-bus-reliability-evidence": "bun scripts/build-tdx-bus-reliability-evidence.mjs",
    "publish:clickhouse-bus-analytics": "bun scripts/publish-clickhouse-bus-analytics.mjs",
    "collect:tdx-bus": "bun scripts/fetch-tdx-taipei-bus-snapshot.mjs --limit 1200 --interval-minutes 5 --loop",
    "collect:tdx-bus:half-day": "bun scripts/fetch-tdx-taipei-bus-snapshot.mjs --limit 1200 --interval-minutes 5 --loop --max-captures 144",
    "collect:tdx-bus:day": "bun scripts/fetch-tdx-taipei-bus-snapshot.mjs --limit 1200 --interval-minutes 5 --loop --max-captures 288",
    "build:cloudflare-bus-projections": "bun scripts/build-cloudflare-bus-projections.mjs",
    "deploy:cloudflare-pages": "bunx wrangler pages deploy",
    "preview:cloudflare-pages": "bunx wrangler pages dev dist --persist-to ../cloudflare/.wrangler-local --ip 127.0.0.1 --port 8788",
    "check": "bun scripts/check-product-copy-boundary.mjs",
    "verify:cloudflare-poc": "bun scripts/verify-cloudflare-poc.mjs",
    "verify:bus-oversight": "bun scripts/verify-bus-oversight-dashboard.mjs",
    "e2e": "bun scripts/run-bus-oversight-e2e.mjs",
    "test": "bun ./tests/run.mjs",
    "test:cloudflare-pages": "node ./functions/test/pagesProjectionFunction.test.mjs && node ./functions/test/pagesBusRouteSignalsFunction.test.mjs",
    "test:mrt-train": "bun ./tests/mrtTrain.test.mjs",
    "test:ontology-components": "bun ./tests/ontologyComponents.test.mjs"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.2",
    "@deck.gl/layers": "^9.3.2",
    "@deck.gl/mapbox": "^9.3.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "gsap": "^3.15.0",
    "maplibre-gl": "^5.24.0",
    "three": "^0.176.0",
    "vite": "^6.3.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
