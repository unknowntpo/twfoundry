{
  "name": "twfoundry-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "tdx:proxy": "bun run scripts/tdx-proxy.ts",
    "check": "bun scripts/check-product-copy-boundary.mjs",
    "check:style": "biome check .",
    "check:fix": "biome check --write .",
    "sample:tdx-bus-delay-apis": "bun scripts/sample-tdx-bus-delay-apis.mjs",
    "build:tdx-bus-reliability-evidence": "bun scripts/build-tdx-bus-reliability-evidence.mjs",
    "publish:clickhouse-bus-analytics": "bun scripts/publish-clickhouse-bus-analytics.mjs",
    "verify:cloudflare-poc": "bun scripts/verify-cloudflare-poc.mjs",
    "verify:bus-oversight": "bun scripts/verify-bus-oversight-dashboard.mjs",
    "test": "vitest run && bun ./tests/run.mjs",
    "test:watch": "vitest",
    "e2e": "playwright test && bun scripts/run-bus-oversight-e2e.mjs"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.2",
    "@deck.gl/layers": "^9.3.2",
    "@deck.gl/mapbox": "^9.3.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "gsap": "^3.15.0",
    "maplibre-gl": "^5.24.0",
    "pinia": "^2.3.0",
    "three": "^0.176.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.0",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.1.10"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.8"
  }
}
