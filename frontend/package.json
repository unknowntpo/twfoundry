{
  "name": "twfoundry-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "fetch:tdx-bus": "bun scripts/fetch-tdx-taipei-bus-snapshot.mjs --limit 1200 --interval-minutes 5",
    "fetch:tdx-bus-history": "bun scripts/fetch-tdx-taipei-bus-history.mjs --top 500000 --interval-minutes 5 --per-slot-limit 1200 --replace-manifest --force",
    "fetch:tdx-bus-route-context": "bun scripts/fetch-tdx-taipei-bus-route-context.mjs --from-archive --limit-routes 40",
    "audit:tdx-bus-route-quality": "bun scripts/audit-tdx-bus-route-quality.mjs",
    "collect:tdx-bus": "bun scripts/fetch-tdx-taipei-bus-snapshot.mjs --limit 1200 --interval-minutes 5 --loop",
    "collect:tdx-bus:half-day": "bun scripts/fetch-tdx-taipei-bus-snapshot.mjs --limit 1200 --interval-minutes 5 --loop --max-captures 144",
    "collect:tdx-bus:day": "bun scripts/fetch-tdx-taipei-bus-snapshot.mjs --limit 1200 --interval-minutes 5 --loop --max-captures 288",
    "test": "bun ./tests/run.mjs",
    "test:mrt-train": "bun ./tests/mrtTrain.test.mjs",
    "test:ontology-components": "bun ./tests/ontologyComponents.test.mjs"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.2",
    "@deck.gl/layers": "^9.3.2",
    "@deck.gl/mapbox": "^9.3.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "maplibre-gl": "^5.24.0",
    "three": "^0.176.0",
    "vite": "^6.3.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
