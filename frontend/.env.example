VITE_MAP_PROVIDER=maplibre
VITE_MAPLIBRE_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
# Optional raster fallback if you do not want to use a hosted MapLibre style.
VITE_MAPLIBRE_RASTER_TILES_URL=

# Keep mock as the default so CI and local smoke tests do not require TDX credentials.
VITE_MRT_LIVEBOARD_SOURCE=mock
VITE_TDX_PROXY_URL=http://localhost:8080

# Server-side only. Use these from `bun run tdx:proxy`; do not prefix them with VITE_.
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=
TDX_AUTH_URL=https://tdx.transportdata.tw/auth/realms/TDXConnect/protocol/openid-connect/token
TDX_API_BASE_URL=https://tdx.transportdata.tw/api/basic/v2
TDX_RATE_LIMIT_PER_SECOND=5
