<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} %-5level %logger{1.} - %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <!-- Diagnose Kafka source split assignment / reader progress -->
    <Logger name="org.apache.flink.connector.kafka" level="DEBUG"/>
    <Logger name="org.apache.flink.runtime.checkpoint" level="INFO"/>
    <!-- Our job -->
    <Logger name="io.twfoundry.backend.streams" level="INFO"/>
    <Root level="INFO">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
