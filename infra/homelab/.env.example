# Optional. Only needed when starting the `cloudflared` profile.
CLOUDFLARE_TUNNEL_TOKEN=

# Local ClickHouse dev credentials.
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=twfoundry_dev

# ---- Track B bus pipeline ----
# TDX credentials for the ingestion service (https://tdx.transportdata.tw).
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=
TDX_CITY=Taipei

# Cloudflare R2 credentials for the scheduler's projection upload (non-interactive
# wrangler). Token needs R2 read/write on the twfoundry-poc-archive bucket.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Track B cycle interval (seconds). Default 300 = match Track A cadence.
TRACK_B_INTERVAL_SECONDS=300
